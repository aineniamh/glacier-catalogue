{
  "name": "Áine's repositories",
  "description": "Tools and workflows for genomic epidemiology",
  "icon": "tools.png",
  "scheme": {
    "background": "#444b6a",
    "foreground": "#cec8eb",
    "font-family": "Helvetica Neue Light, Helvetica, sans-serif",
    "font-size": "12px",
    "title-background": "#e5d5d9",
    "title-foreground": "#c687ac",
    "title-font-family": "Helvetica Neue Thin, Helvetica, sans-serif",
    "title-font-size": "18px",
    "project-background": "#e5d5d9",
    "project-foreground": "#c687ac",
    "project-title-background": "#444b6a",
    "project-title-foreground": "#cec8eb"
  },
  "materialTheme": {
    "palette": {
      "mode": "light",
      "primary": {
        "main": "#e5d5d9",
        "dark": "#033940",
        "light": "#19A699",
        "contrastText": "#444b6a"
      },
      "secondary": {
        "main": "#BF4B43",
        "light": "#E06961",
        "contrastText": "#c687ac"
      },
      "background": {
        "default": "#e6d595",
        "paper": "#c687ac"
      },
      "error": {
        "main": "#d95a47",
        "contrastText": "#444b6a"
      },
      "warning": {
        "main": "#F6A14C",
        "contrastText": "#444b6a"
      },
      "info": {
        "main": "#016E85",
        "contrastText": "#444b6a"
      },
      "success": {
        "main": "#40847D",
        "contrastText": "#444b6a"
      },
      "divider": "#cec8eb",
      "text": {
        "primary": "#000000",
        "secondary": "#000000",
        "disabled": "#000000"
      }
    },
    "typography": {
      "fontFamily": "Open Sans"
    },
    "overrides": {
      "MuiAppBar": {
        "colorInherit": {
          "backgroundColor": "#444b6a",
          "color": "#fff"
        }
      }
    },
    "props": {
      "MuiAppBar": {
        "color": "inherit"
      }
    }
  },
  "sections": [
    {
      "name": "phylogenetics",
      "description": "Workflows for phylogenetic analysis of viral genomes",
      "icon": "raccoon_logo.png",
      "workflows": [
        {
          "name": "raccoon-nf",
          "repo": "artic-network/raccoon-nf",
          "version": "latest"
        },
        {
          "name": "snipit",
          "repo": "aineniamh/snipit",
          "version": "latest"
        }
      ]
    },
    {
      "name": "SARS-CoV-2",
      "description": "Workflows for SARS-CoV-2 analysis",
      "icon": "sars-cov-2_icon.png",
      "workflows": [
        {
          "name": "pangolin-nf",
          "repo": "cov-lineages/pangolin",
          "version": "latest"
        },
        {
          "name": "civet-nf",
          "repo": "artic-network/civet",
          "version": "latest"
        }
      ]
    },
    {
      "name": "MPXV",
      "description": "Workflows for Mpox virus",
      "icon": "mpxv.png",
      "scheme": {
        "project-background": "#c687ac",
        "project-foreground": "#e5d5d9",
        "project-title-background": "#BF4B43",
        "project-title-foreground": "#E6D595"
      },
      "workflows": [
        {
          "name": "squirrel-nf",
          "repo": "artic-network/squirrel-nf"
        }
      ]
    }
  ]
}
